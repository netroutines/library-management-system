<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="006-add-column-genre_id-to-books" author="netroutines">

        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="books" columnName="genre_id" />
            </not>
        </preConditions>

        <addColumn tableName="books">
            <column name="genre_id" type="bigint unsigned">
                <constraints nullable="false" />
            </column>
        </addColumn>

        <createIndex tableName="books" indexName="idx_books_genre_id">
            <column name="genre_id" />
        </createIndex>

        <addForeignKeyConstraint
                baseTableName="books"
                baseColumnNames="genre_id"
                referencedTableName="genres"
                referencedColumnNames="id"
                constraintName="fk_books_genre"
                onUpdate="RESTRICT"
                onDelete="RESTRICT" />

        <rollback>
            <dropIndex tableName="books" indexName="idx_books_genre_id" />
            <dropForeignKeyConstraint baseTableName="books" constraintName="fk_books_genre" />
            <dropColumn tableName="books" columnName="genre_id" />
        </rollback>

    </changeSet>

</databaseChangeLog>
